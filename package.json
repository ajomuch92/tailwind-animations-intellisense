{
  "name": "tailwind-animations-intellisense",
  "displayName": "tailwind-animations-intellisense",
  "description": "This project is a helper for autocomplete support for the tailwind-animations (by @midudev) package in VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "icon": "images/icon.png",
  "categories": [
    "Other"
  ],
  "publisher": "ajomuch92",
  "author": {
    "name": "ajomuch92"
  },
  "repository": {
    "url": "https://github.com/ajomuch92/tailwind-animations-intellisense"
  },
  "license": "MIT",
  "activationEvents": [
    "onLanguage:html", "onLanguage:vue", "workspaceContains:package.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Tailwind Animations IntelliSense",
      "properties": {
        "tailwindAnimations.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Tailwind Animations IntelliSense"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
